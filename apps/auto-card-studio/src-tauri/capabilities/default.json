{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "A.U.T.O 主窗口的本地存储、加密密钥与用户配置模型端点权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*" },
        { "url": "http://*:*" }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "stronghold:default",
    "stronghold:allow-remove-store-record"
  ]
}
